{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A hardware module module for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "oldPrice": { "type": "number" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "tag": { "type": "string" },
        "imageUrl": { "type": "string" },
        "image": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Visual promotional banner for hero section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tagline": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "imageUrl"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global site configurations",
      "type": "object",
      "properties": {
        "siteTitle": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase order",
      "type": "object",
      "properties": {
        "customer": { "type": "object" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Store of hardware modules"
    },
    "/banners/{bannerId}": {
      "schema": "Banner",
      "description": "Store of promotional banners"
    },
    "/settings/site_config": {
      "schema": "Settings",
      "description": "Global system configurations"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/admins/{userId}": {
      "schema": "object",
      "description": "Admin privileges map"
    }
  }
}
