rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'dm8115589@gmail.com' ||
        request.auth.token.email == 'klgadjenix@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Products Collection
    match /products/{productId} {
      function isValidProduct(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.category is string && data.category.size() > 0 &&
               (data.get('description', '') is string) &&
               (data.get('tag', '') is string);
      }

      allow get, list: if true; // Publicly accessible inventory
      
      allow create: if isAdmin() && isValidProduct(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() && isValidProduct(incoming()) &&
                      incoming().updatedAt == request.time;
      
      allow delete: if isAdmin();
    }

    // 2. Banners Collection
    match /banners/{bannerId} {
      function isValidBanner(data) {
        return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
               data.imageUrl is string && data.imageUrl.size() > 0;
      }

      allow get, list: if true;

      allow create: if isAdmin() && isValidBanner(incoming()) &&
                      incoming().createdAt == request.time;
      
      allow update: if isAdmin() && isValidBanner(incoming()) &&
                      incoming().updatedAt == request.time;
      
      allow delete: if isAdmin();
    }

    // 3. Settings Collection
    match /settings/{settingId} {
      allow get: if true;
      allow list: if isAdmin();
      
      allow write: if isAdmin() && isValidId(settingId);
    }

    // 4. Orders Collection
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.customer is map &&
               data.items is list && data.items.size() > 0 &&
               data.total is number && data.total >= 0 &&
               data.status in ['pending', 'processing', 'completed', 'cancelled'];
      }

      allow create: if isValidOrder(incoming()) && 
                      incoming().createdAt == request.time;
      
      allow get: if isAdmin() || (isSignedIn() && resource.data.customer.email == request.auth.token.email);
      allow list: if isAdmin();
      
      allow update: if isAdmin() && 
                      incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
      
      allow delete: if isAdmin();
    }

    // 5. Admins Collection (Private)
    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Only manageable via console for safety or a specific super-admin
    }
  }
}
